# .env.example
# Copia este archivo a .env y reemplaza los valores reales.
# Las variables que necesites usar desde el navegador deben empezar con VITE_.

VITE_API_URL=https://api.example.com
VITE_APP_NAME="Qreativo Studio"
VITE_CONTACT_EMAIL=contacto@qreativo.studio

# Si necesitas variables sólo de servidor, bórrale el prefijo VITE_ y no las uses en código cliente.
# ASTRO_SECRET_KEY=valor-secreto
